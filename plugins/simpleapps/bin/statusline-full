#!/usr/bin/env bash
# SimpleApps status line (full): user:repo (branch) | version | model | context k/k (%)
# Usage: set in ~/.claude/settings.json:
#   "statusLine": { "type": "command", "command": "statusline-full" }
input=$(cat)

cache_file="${HOME}/.cache/augur-skills/gh-user"
if [ -f "$cache_file" ] && [ -z "$(find "$cache_file" -mmin +120 2>/dev/null)" ]; then
  user=$(cat "$cache_file")
else
  user=$(gh api user --jq .login 2>/dev/null || whoami)
  mkdir -p "$(dirname "$cache_file")"
  echo "$user" > "$cache_file"
fi
model=$(echo "$input" | jq -r '.model.display_name // empty')
project_dir=$(echo "$input" | jq -r '.workspace.project_dir // empty')
version=$(echo "$input" | jq -r '.version // empty')
context_pct=$(echo "$input" | jq -r '.context_window.used_percentage // empty')
context_size=$(echo "$input" | jq -r '.context_window.context_window_size // empty')

context_used_k=""
context_total_k=""
if [ -n "$context_pct" ] && [ -n "$context_size" ]; then
  context_used_k=$(awk -v p="$context_pct" -v s="$context_size" 'BEGIN { printf "%.0f", (p * s / 100) / 1000 }')
  context_total_k=$(awk -v s="$context_size" 'BEGIN { printf "%.0f", s / 1000 }')
fi

project_name="unknown"
[ -n "$project_dir" ] && project_name=$(basename "$project_dir")

branch=""
if [ -d "${project_dir}/repo/.git" ]; then
  branch=$(git -C "${project_dir}/repo" branch --show-current 2>/dev/null)
elif [ -d "${project_dir}/.git" ]; then
  branch=$(git -C "$project_dir" branch --show-current 2>/dev/null)
fi

# ANSI colors
green='\033[32m'
blue='\033[34m'
cyan='\033[36m'
yellow='\033[33m'
magenta='\033[35m'
dim='\033[2m'
reset='\033[0m'

printf "${green}%s${dim}:${blue}%s${reset}" "$user" "$project_name"
[ -n "$branch" ] && printf " ${dim}(%s)${reset}" "$branch"
[ -n "$version" ] && printf " ${dim}|${reset} ${cyan}v%s${reset}" "$version"
[ -n "$model" ] && printf " ${dim}|${reset} ${yellow}%s${reset}" "$model"
if [ -n "$context_pct" ]; then
  if [ -n "$context_used_k" ] && [ -n "$context_total_k" ]; then
    printf " ${dim}|${reset} ${magenta}ctx:%sK/%sK (%s%%)${reset}" "$context_used_k" "$context_total_k" "$context_pct"
  else
    printf " ${dim}|${reset} ${magenta}ctx:%s%%${reset}" "$context_pct"
  fi
fi
printf '\n'
